<Window x:Class="FotoLibraryCleaner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:FotoLibraryCleaner.App.ViewModels"
        mc:Ignorable="d"
        Title="Foto Library Cleaner"
        Height="900"
        Width="1480"
        MinHeight="720"
        MinWidth="1220"
        Background="#FFF5F6F8">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                Background="White"
                BorderBrush="#FFD8DDE6"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#FF111827"
                               Text="Foto Library Cleaner" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#FF5B6472"
                               Text="Windows review app for duplicate photo detection, metadata checks, and safe cleanup workflows." />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,8"
                        Background="#FFF2F4F7"
                        CornerRadius="6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#FF111827"
                                       Text="{Binding BusyLabel}" />
                            <TextBlock Margin="10,0,0,0"
                                       Foreground="#FF5B6472"
                                       Text="{Binding ScanPhase}" />
                        </StackPanel>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#FF5B6472"
                                   Text="{Binding StatusText}" />
                        <ProgressBar Margin="0,10,0,0"
                                     Width="320"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding ProgressValue, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="20"
                    Background="White"
                    BorderBrush="#FFD8DDE6"
                    BorderThickness="1"
                    CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#FF111827"
                                   Text="Scan Setup" />

                        <TextBlock Margin="0,20,0,6"
                                   Foreground="#FF5B6472"
                                   Text="Source folder" />
                        <DockPanel LastChildFill="True">
                            <Button Width="86"
                                    Margin="12,0,0,0"
                                    HorizontalAlignment="Right"
                                    Command="{Binding BrowseSourceCommand}"
                                    Content="Browse"
                                    DockPanel.Dock="Right" />
                            <TextBox Padding="10,8"
                                     Text="{Binding SourceFolder, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <TextBlock Margin="0,16,0,6"
                                   Foreground="#FF5B6472"
                                   Text="Duplicates folder" />
                        <DockPanel LastChildFill="True">
                            <Button Width="86"
                                    Margin="12,0,0,0"
                                    HorizontalAlignment="Right"
                                    Command="{Binding BrowseDuplicatesCommand}"
                                    Content="Browse"
                                    DockPanel.Dock="Right" />
                            <TextBox Padding="10,8"
                                     Text="{Binding DuplicatesFolder, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <TextBlock Margin="0,16,0,6"
                                   Foreground="#FF5B6472"
                                   Text="Threshold" />
                        <DockPanel>
                            <TextBox Width="72"
                                     Padding="10,8"
                                     Text="{Binding Threshold, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="12,8,0,0"
                                       Foreground="#FF5B6472"
                                       Text="0 = exact, 5 = balanced, 10+ = more permissive" />
                        </DockPanel>

                        <CheckBox Margin="0,18,0,0"
                                  Content="Use fast mode (LSH bucketing)"
                                  IsChecked="{Binding UseFastMode}" />
                        <CheckBox Margin="0,8,0,0"
                                  Content="Dry run only"
                                  IsChecked="{Binding DryRun}" />
                        <CheckBox Margin="0,8,0,0"
                                  Content="Include subfolders"
                                  IsChecked="{Binding IncludeSubfolders}" />

                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Padding="12,10"
                                    Command="{Binding ScanCommand}"
                                    Content="Start Scan" />
                            <Button Grid.Column="2"
                                    Padding="12,10"
                                    Command="{Binding CancelScanCommand}"
                                    Content="Cancel Scan" />
                        </Grid>

                        <Button Margin="0,12,0,0"
                                Padding="12,10"
                                Command="{Binding ExportReviewPlanCommand}"
                                Content="Export Review Plan CSV" />

                        <Border Margin="0,24,0,0"
                                Padding="14"
                                Background="#FFF8FAFC"
                                BorderBrush="#FFE4E7EC"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="#FF111827"
                                           Text="Scan status" />
                                <UniformGrid Margin="0,12,0,0"
                                             Columns="2"
                                             Rows="2">
                                    <Border Margin="0,0,10,10"
                                            Padding="10"
                                            Background="White"
                                            BorderBrush="#FFE4E7EC"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Foreground="#FF667085"
                                                       Text="Discovered" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF111827"
                                                       Text="{Binding FilesDiscovered}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            Background="White"
                                            BorderBrush="#FFE4E7EC"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Foreground="#FF667085"
                                                       Text="Analyzed" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF111827"
                                                       Text="{Binding ImagesAnalyzed}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,10,0"
                                            Padding="10"
                                            Background="White"
                                            BorderBrush="#FFE4E7EC"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Foreground="#FF667085"
                                                       Text="Skipped" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF111827"
                                                       Text="{Binding ImagesSkipped}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="10"
                                            Background="White"
                                            BorderBrush="#FFE4E7EC"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Foreground="#FF667085"
                                                       Text="Groups" />
                                            <TextBlock Margin="0,6,0,0"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF111827"
                                                       Text="{Binding GroupsFoundLive}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#FFD8DDE6"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="18,16"
                            BorderBrush="#FFD8DDE6"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#FF111827"
                                       Text="Duplicate Groups" />
                            <Border Padding="10,4"
                                    Background="#FFF2F4F7"
                                    CornerRadius="999"
                                    DockPanel.Dock="Right">
                                <TextBlock Foreground="#FF344054"
                                           Text="{Binding GroupCount, StringFormat={}{0} groups}" />
                            </Border>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <ListBox ItemsSource="{Binding Groups}"
                                 SelectedItem="{Binding SelectedGroup}"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:DuplicateGroupViewModel}">
                                    <Border Margin="12,8"
                                            Padding="16"
                                            Background="#FFF8FAFC"
                                            BorderBrush="#FFE4E7EC"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="#FF111827"
                                                       Text="{Binding Header}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#FF475467"
                                                       Text="{Binding Summary}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF101828"
                                                       Text="{Binding Primary.FileName}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#FF667085"
                                                       Text="{Binding Primary.Path}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#FF667085"
                                   Text="{Binding EmptyStateText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GroupCount}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="4"
                    Background="White"
                    BorderBrush="#FFD8DDE6"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="18,16"
                            BorderBrush="#FFD8DDE6"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#FF111827"
                                       Text="Review" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#FF5B6472"
                                       Text="{Binding SelectedGroup.Summary}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Padding="16"
                            BorderBrush="#FFD8DDE6"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#FF111827"
                                       Text="Candidates in selected group" />
                            <ListBox Margin="0,12,0,0"
                                     ItemsSource="{Binding SelectedGroup.Matches}"
                                     SelectedItem="{Binding SelectedGroup.SelectedMatch}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:PhotoCandidateMatchViewModel}">
                                        <Border Margin="0,0,12,0"
                                                Padding="12"
                                                Background="#FFF8FAFC"
                                                BorderBrush="#FFE4E7EC"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel Width="190">
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="#FF111827"
                                                           Text="{Binding FileName}" />
                                                <ComboBox Margin="0,8,0,0"
                                                          ItemsSource="{Binding AvailableActions}"
                                                          SelectedItem="{Binding SelectedAction, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="#FF667085"
                                                           Text="{Binding Resolution}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="#FF667085"
                                                           Text="{Binding Distance, StringFormat=Distance: {0}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2" Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="16"
                                Background="#FFF8FAFC"
                                BorderBrush="#FFE4E7EC"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="220" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Background="#FFEFF2F6"
                                        CornerRadius="4">
                                    <Grid>
                                        <Image Source="{Binding SelectedGroup.Primary.PreviewImage}"
                                               Stretch="Uniform" />
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#FF98A2B3"
                                                   Text="No preview available">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedGroup.Primary.HasPreview}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#FF111827"
                                               Text="{Binding SelectedGroup.Primary.FileName}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.Primary.Path}" />
                                    <TextBlock Margin="0,14,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.Primary.Resolution, StringFormat=Resolution: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.Primary.FileSize, StringFormat=File size: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.Primary.PixelCount, StringFormat=Pixels: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.Primary.Format, StringFormat=Format: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.Primary.Md5, StringFormat=MD5: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.Primary.TakenAt, StringFormat=Taken at: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.Primary.QualityScore, StringFormat=Quality score: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.Primary.Reason, StringFormat=Reason: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="Review action: Keep" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="16"
                                Background="#FFF8FAFC"
                                BorderBrush="#FFE4E7EC"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="220" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Background="#FFEFF2F6"
                                        CornerRadius="4">
                                    <Grid>
                                        <Image Source="{Binding SelectedGroup.ComparisonTarget.PreviewImage}"
                                               Stretch="Uniform" />
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#FF98A2B3"
                                                   Text="No preview available">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedGroup.ComparisonTarget.HasPreview}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#FF111827"
                                               Text="{Binding SelectedGroup.ComparisonTarget.FileName}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.ComparisonTarget.Path}" />
                                    <TextBlock Margin="0,14,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.ComparisonTarget.Resolution, StringFormat=Resolution: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.ComparisonTarget.FileSize, StringFormat=File size: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.ComparisonTarget.PixelCount, StringFormat=Pixels: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.ComparisonTarget.Format, StringFormat=Format: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.ComparisonTarget.Md5, StringFormat=MD5: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.ComparisonTarget.TakenAt, StringFormat=Taken at: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.ComparisonTarget.QualityScore, StringFormat=Quality score: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.ComparisonTarget.Reason, StringFormat=Reason: {0}}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FF475467"
                                               Text="{Binding SelectedGroup.SelectedMatch.SelectedAction, StringFormat=Review action: {0}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="18,12"
                Background="White"
                BorderBrush="#FFD8DDE6"
                BorderThickness="1,1,1,0">
            <DockPanel>
                <TextBlock Foreground="#FF475467"
                           Text="{Binding StatusText}" />
                <TextBlock DockPanel.Dock="Right"
                           Foreground="#FF475467"
                           Text=".NET 10 WPF shell in progress" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
